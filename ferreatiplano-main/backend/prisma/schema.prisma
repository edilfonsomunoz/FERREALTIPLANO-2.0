// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDEDOR
  CLIENTE
}

enum OrderStatus {
  NUEVO
  EN_PREPARACION
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum PaymentMethod {
  CULQI
  YAPE
  CONTRA_ENTREGA
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  RECHAZADO
}

enum DocType {
  BOLETA
  FACTURA
}

model User {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  rol       Role     @default(CLIENTE)
  telefono  String?
  direccion String?
  ruc       String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pedidos   Pedido[] @relation("ClientePedidos")
  ventas    Pedido[] @relation("VendedorPedidos")
}

model Producto {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?  @db.Text
  precio      Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  categoria   String
  imagenes    String[]
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pedidoItems PedidoItem[]
  
  @@index([categoria, activo])
  @@index([nombre, activo])
}

model Proveedor {
  id                String   @id @default(cuid())
  nombre            String
  ruc               String?
  contacto          String?
  email             String?
  telefono          String?
  direccion         String?
  productosSuministra String?
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
}

model Pedido {
  id               String        @id @default(cuid())
  clienteId        String
  vendedorId       String?
  estado           OrderStatus   @default(NUEVO)
  total            Decimal       @db.Decimal(10, 2)
  metodoPago       PaymentMethod
  direccionEntrega String
  lat              Float?
  lng              Float?
  costoDelivery    Decimal       @default(0.00) @db.Decimal(10, 2)
  notas            String?       @db.Text
   yapeReference     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  cliente          User          @relation("ClientePedidos", fields: [clienteId], references: [id])
  vendedor         User?         @relation("VendedorPedidos", fields: [vendedorId], references: [id])
  items            PedidoItem[]
  pago             Pago?
  comprobante      Comprobante?

  @@index([estado, createdAt(sort: Desc)])
  @@index([clienteId, createdAt])
}

model PedidoItem {
  id             String   @id @default(cuid())
  pedidoId       String
  productoId     String
  cantidad       Int
  precioUnitario Decimal  @db.Decimal(10, 2)

  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])
}

model Pago {
  id            String        @id @default(cuid())
  pedidoId      String        @unique
  monto         Decimal       @db.Decimal(10, 2)
  metodo        PaymentMethod
  estado        PaymentStatus @default(PENDIENTE)
  culqiChargeId String?
  createdAt     DateTime      @default(now())

  pedido        Pedido        @relation(fields: [pedidoId], references: [id])
}

model Comprobante {
  id          String   @id @default(cuid())
  pedidoId    String   @unique
  tipo        DocType
  serie       String
  numero      Int
  sunatHash   String
  pdfUrl      String
  xmlUrl      String?
  estado      String   @default("EMITIDO")
  createdAt   DateTime @default(now())

  pedido      Pedido   @relation(fields: [pedidoId], references: [id])
}